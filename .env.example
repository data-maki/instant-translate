SONIOX_API_KEY=your_soniox_api_key_here

# Frontend defaults to http://localhost:8000 if unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Keys below are for the diarization / translation / identification tests
# described in docs/diarization-alternatives.md. Only required for those tests.

# Replicate-hosted pyannote 3.1 (test 1: diarization, test 3: embeddings).
REPLICATE_API_TOKEN=your_replicate_api_token_here

# HuggingFace token for direct pyannote-audio / pyannote-embedding usage
# (alternative to Replicate; needed once we move pyannote local).
HF_TOKEN=your_hf_token_here

# DeepL Free or Pro translation API (test 2: translation A/B).
DEEPL_API_KEY=your_deepl_api_key_here

# OpenAI: GPT-4o translation (test 2), plus any later Whisper-API or
# gpt-realtime experiments.
OPENAI_API_KEY=your_openai_api_key_here
