{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "incremental": false,
    "isolatedModules": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".test-build",
    "rootDir": "src",
    "target": "ES2020",
    "tsBuildInfoFile": ".test-build/tsconfig.tsbuildinfo",
    "types": ["node"]
  },
  "include": [
    "src/lib/phrase-text.ts",
    "src/lib/phrase-text.test.ts"
  ]
}
